# Self-hosted LLM provider for AI chat: anthropic, openai, or ollama
RAY_LLM_PROVIDER=anthropic

# Provider-specific LLM settings
RAY_LLM_API_KEY=
RAY_LLM_BASE_URL=
RAY_LLM_MODEL=claude-sonnet-4-6

# Legacy Anthropic fallback (still supported)
ANTHROPIC_API_KEY=

# Plaid credentials for bank sync — https://dashboard.plaid.com
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=production

# Database encryption key (any strong passphrase)
DB_ENCRYPTION_KEY=

# Separate key for encrypting stored Plaid access tokens (any strong passphrase)
PLAID_TOKEN_SECRET=
